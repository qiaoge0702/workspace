{
  // ==================== 多项目工作区配置 ====================
  
  // Java 项目配置
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.compile.nullAnalysis.mode": "automatic",
  
  // Spring Boot 支持
  "spring-boot.ls.checkJVM": false,
  
  // Python 配置 (DEMAS Server)
  "python.analysis.extraPaths": [
    "${workspaceFolder}/cli-specialtrucks/demas/apps/server/src"
  ],
  "python.defaultInterpreterPath": "${workspaceFolder}/cli-specialtrucks/demas/apps/server/.venv/bin/python",
  
  // TypeScript/React 配置 (DEMAS Desktop + Junke QY MP)
  "typescript.tsdk": "${workspaceFolder}/cli-specialtrucks/demas/apps/desktop/node_modules/typescript/lib",
  
  // 文件排除 - 减少索引噪音
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/target": true,
    "**/build": true,
    "**/.gradle": true,
    "**/unpackage": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.idea": true
  },
  
  // 搜索排除
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/build": true,
    "**/.gradle": true,
    "**/unpackage": true,
    "**/__pycache__": true,
    "**/.venv": true
  }
}
